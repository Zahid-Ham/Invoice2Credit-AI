# Server Configuration
PORT=8000
HOST=0.0.0.0
DEBUG=True

# Firebase Credentials (JSON string or path to JSON file)
FIREBASE_CREDENTIALS_PATH=app/config/firebase-service-account.json

# AI Configuration (Groq API Key)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Blockchain Configurations
BLOCKCHAIN_NETWORK=local
LOCAL_BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology
BLOCKCHAIN_VERIFIER_PRIVATE_KEY=

# Cloudinary Storage Configuration
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_URL=your-cloudinary-connection-url
